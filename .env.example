OPENAI_API_KEY=
# Optional override if using a gateway
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.6

# Web
NEXT_PUBLIC_APP_NAME=Prompt Race

SANDBOX_ROOT=
# Required for challenge output and model run_command. 
# docker: Uses Docker with no network.
# local-dev: Local host execution is for trusted development only; never use it in production.

SANDBOX_RUNNER=docker

# Backend selection. Defaults keep local development self-contained.
ATTEMPT_REPOSITORY=json
WORKSPACE_BACKEND=local-fs
RUNNER_BACKEND=docker

# Cloud Run / Google Cloud demo backend.
# ATTEMPT_REPOSITORY=firestore
# WORKSPACE_BACKEND=cloud-storage
# RUNNER_BACKEND=cloud-run-sandbox
# GOOGLE_CLOUD_PROJECT=
# WORKSPACE_BUCKET=

# Production runner images: set all values to immutable registry digests.
# The web process rejects tag-only values when NODE_ENV=production.
# RUNNER_IMAGE_NODE_CLI=registry.example/prompt-race/node-cli@sha256:<digest>
# RUNNER_IMAGE_NODE_HTTP=registry.example/prompt-race/node-http@sha256:<digest>
# RUNNER_IMAGE_WEB_PREVIEW=registry.example/prompt-race/web-preview@sha256:<digest>
# RUNNER_IMAGE_PLAYWRIGHT=registry.example/prompt-race/playwright@sha256:<digest>

# Development attempt persistence. The JSON file stores sandboxRef, never an
# absolute sandbox path. Set ATTEMPT_REPOSITORY=memory for isolated tests only.
# ATTEMPT_STORE_PATH=.runs/attempts.json
# ATTEMPT_REPOSITORY=memory
